"correctCount\":11,\"total_n_questions\":12,\"quiz_passed\":true,\"bonus_accuracy\":0.75},{\"rt\":185523,\"response\":{\"strategy\":\"- when a toll appeared in a column on a toll + column day, I would avoid travelling in that column\\n- when a toll appeared in a row on a toll + row day, I would avoid travelling in that row\\n- when a tip appeared in a column on a tip + column day, I would try to travel in that row\\n- when a tip appeared in a row on a tip + row day, I would try to travel in that row\\n- avoiding travel in a column which doesnt have any known entities on a toll + column day (too risky)\\n- avoiding travel in a row which doesnt have any known entities on a toll + row day (too risky)\\n- occasionally travelling through rows to learn about the contents of columns on a column day, and vice versa\\n\"},\"trial_type\":\"survey-text\",\"trial_index\":415,\"time_elapsed\":1919100,\"internal_node_id\":\"0.0-372.0\",\"final_zoom_factor\":0.88,\"blue_key\":\"P\",\"green_key\":\"Q\",\"correctCount\":11,\"total_n_questions\":12,\"quiz_passed\":true,\"bonus_accuracy\":0.75},{\"rt\":73632,\"response\":{\"tips_vs_tolls\":\"my strategy did not differ massively, but I would be less likely to travel through a column or row which doesn't have any revealed squares on a toll day compared to a tip day\"},\"trial_type\":\"survey-text\",\"trial_index\":416,\"time_elapsed\":1992732,\"internal_node_id\":\"0.0-373.0\",\"final_zoom_factor\":0.88,\"blue_key\":\"P\",\"green_key\":\"Q\",\"correctCount\":11,\"total_n_questions\":12,\"quiz_passed\":true,\"bonus_accuracy\":0.75},{\"rt\":101331,\"response\":{\"rows_vs_columns\":\"- mostly I used the same strategy -- start off by identifying some squares, then target certain rows and columns depending on what I already knew existed in those squares\\n- in the first dispatch, I would choose the initial route that would reveal the most about future dispatch routes (i.e. which ones covered the most ground adjacent to the next dispatch routes)\"},\"trial_type\":\"survey-text\",\"trial_index\":417,\"time_elapsed\":2094064,\"internal_node_id\":\"0.0-374.0\",\"final_zoom_factor\":0.88,\"blue_key\":\"P\",\"green_key\":\"Q\",\"correctCount\":11,\"total_n_questions\":12,\"quiz_passed\":true,\"bonus_accuracy\":0.75},{\"rt\":62662,\"response\":{\"lookahead\":\"I would look far ahead on the first job/dispatch, but this would considerably drop off throughout the day. This is because as more information got revealed, it became much easier to make decisions as the dispatches progressed\"},\"trial_type\":\"survey-text\",\"trial_index\":418,\"time_elapsed\":2156727,\"internal_node_id\":\"0.0-375.0\",\"final_zoom_factor\":0.88,\"blue_key\":\"P\",\"green_key\":\"Q\",\"correctCount\":11,\"total_n_questions\":12,\"quiz_passed\":true,\"bonus_accuracy\":0.75},{\"rt\":7182,\"response\":{\"other_comments\":\"I enjoyed the experiment\"},\"trial_type\":\"survey-text\",\"trial_index\":419,\"time_elapsed\":2163910,\"internal_node_id\":\"0.0-376.0\",\"final_zoom_factor\":0.88,\"blue_key\":\"P\",\"green_key\":\"Q\",\"correctCount\":11,\"total_n_questions\":12,\"quiz_passed\":true,\"bonus_accuracy\":0.75},{\"rt\":4457,\"response\":\" \",\"trial_type\":\"html-keyboard-response\",\"trial_index\":420,\"time_elapsed\":2168367,\"internal_node_id\":\"0.0-377.0\",\"final_zoom_factor\":0.88,\"blue_key\":\"P\",\"green_key\":\"Q\",\"correctCount\":11,\"total_n_questions\":12,\"quiz_passed\":true,\"bonus_accuracy\":0.75},{\"rt\":48428,\"response\":{\"NFC1.\":\"uncertain\",\"NFC2.\":\"somewhat uncharacteristic of me\",\"NFC3.\":\"somewhat uncharacteristic of me\",\"NFC4.\":\"somewhat uncharacteristic of me\",\"NFC5.\":\"uncertain\",\"NFC6.\":\"somewhat characteristic of me\",\"screener\":\"extremely characteristic of me\"},\"question_order\":[0,1,2,3,4,5,6],\"task\":\"NFC\",\"trial_type\":\"survey-multi-choice\",\"trial_index\":421,\"time_elapsed\":2216797,\"internal_node_id\":\"0.0-378.0-0.0-0.0\",\"final_zoom_factor\":0.88,\"blue_key\":\"P